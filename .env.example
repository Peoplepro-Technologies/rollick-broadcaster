# ── App ──────────────────────────────────────────────────────
APP_NAME="Rollick Broadcaster"
APP_BASE_URL=http://localhost:8000
BASE_PUBLIC_URL=http://localhost:8000
LINK_TOKEN_TTL_DAYS=30

# ── Admin bootstrap ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# ── Session signing ──────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=broadcaster.db

# ── Anti-spam ────────────────────────────────────────────────
COMMENT_MAX_PER_IP_PER_HOUR=5
COMMENT_MAX_PER_LINK_LIFETIME=3
COMMENT_COOLDOWN_SECONDS=30

# ── Anonymity (rotate quarterly) ────────────────────────────
IP_HASH_PEPPER=change-me-quarterly

# ── Media signing (used in v1.1 for signed CDN URLs) ────────
MEDIA_SIGN_SECRET=change-me

# ── SMTP (optional in v1; falls back to mock if empty) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── WhatsApp Business API (optional in v1) ───────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_COUNTRY_CODE=91
